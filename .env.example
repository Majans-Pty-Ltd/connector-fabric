# Azure AD Service Principal credentials
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# Power BI XMLA endpoint
# Format: powerbi://api.powerbi.com/v1.0/myorg/YourWorkspaceName
PBI_XMLA_ENDPOINT=powerbi://api.powerbi.com/v1.0/myorg/YourWorkspaceName

# Dataset (catalog) name to connect to
PBI_DATASET_NAME=YourDatasetName
